# Скопировать на сервере: cp deploy/env.production.example .env && nano .env
# Секреты (YANDEX_API_KEY и т.д.) — только на сервере, не в git.

SCRAPER_BACKEND=httpx
AGENT_PROVIDER=local

DATABASE_URL=sqlite+aiosqlite:///./data/leads.db
REQUEST_DELAY_SEC=2

# Только localhost — снаружи заходите через nginx (порт 80)
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8765

YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt
YANDEX_BASE_URL=https://llm.api.cloud.yandex.net/v1
YANDEX_USE_RESPONSES_API=false
YANDEX_ENABLE_WEB_SEARCH=false
