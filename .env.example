# Бэкенд извлечения: httpx (бесплатно) | playwright | crawl4ai | yandex | scrapegraph
SCRAPER_BACKEND=httpx

# Агенты: local | yandex (LLM-роли Search/Enrich через Yandex AI Studio)
AGENT_PROVIDER=local

# --- Yandex AI Studio (https://aistudio.yandex.ru/ru/developers) ---
YANDEX_API_KEY=
# ID каталога (console.yandex.cloud → каталог → b1g…)
YANDEX_FOLDER_ID=b1gai2s8u8p5vdje63jo
# Короткое имя модели ИЛИ полный URI (достаточно одного из двух полей с folder):
YANDEX_MODEL=yandexgpt
# YANDEX_MODEL=gpt://b1gai2s8u8p5vdje63jo/yandexgpt
YANDEX_BASE_URL=https://llm.api.cloud.yandex.net/v1
# Responses API — у Yandex Cloud обычно 404; оставьте false (chat/completions)
YANDEX_USE_RESPONSES_API=false
# Опционально: web_search tool в агенте поиска (дороже)
YANDEX_ENABLE_WEB_SEARCH=false
YANDEX_MAX_HTML_CHARS=48000

# ScrapeGraphAI (платно)
SGAI_API_KEY=

# Crawl4AI + Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# ГосПлан API
GOSPLAN_API_URL=https://v2test.gosplan.info
GOSPLAN_API_KEY=

DATABASE_URL=sqlite+aiosqlite:///./data/leads.db
REQUEST_DELAY_SEC=2

DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8765
